#cloud-config
# cf-base baseline — Ubuntu 24.04 LTS. See cloud-init/RATIONALE.md.

manage_etc_hosts: true

package_update: true
package_upgrade: true

packages:
  - ca-certificates
  - gnupg
  - openssh-server
  - mosh
  - tailscale
  - ufw
  - unattended-upgrades
  - apt-listchanges
  - fail2ban
  - docker-ce
  - docker-ce-cli
  - containerd.io
  - docker-compose-plugin
  - git
  - nano
  - tmux
  - screen
  - jq
  - sqlite3
  - htop
  - curl
  - wget
  - rsync
  - tree
  - unzip
  - ripgrep
  - fd-find
  - lsof
  - strace
  - tcpdump
  - dnsutils
  - ncdu
  - dmidecode
  - nodejs

users:
  - name: deploy
    uid: 1000
    shell: /bin/bash
    sudo: ALL=(ALL) NOPASSWD:ALL
    groups:
      - sudo
      - docker
      - systemd-journal
    ssh_authorized_keys:
__INCLUDE_OPERATOR_PUBKEYS__

